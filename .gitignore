# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated files
/src/generated/prisma

# database files
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.bak*
prisma/prisma/

# user uploaded files
/public/uploads/*
!/public/uploads/.gitkeep

# received card images (stored by postcard ID)
/data/received/*
!/data/received/.gitkeep

# log files
logs/
*.log
test-output.log

# test reports
reports/
test-results/
playwright-report/
e2e-report/

# IDE
.vscode/
.idea/

# .workbuddy / internal tools
.workbuddy/
.codebuddy/
.playwright-cli/

# internal docs
docs/

# temp files
tmp-*.ts
tmp-*.js
*.tmp
data/wordcloud-dictionary.json

# analysis scripts output (contains personal postcard data)
scripts/*_coding_results.json